<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<!-- Allows absolute positioning of the BorderPane -->
<AnchorPane prefHeight="400" prefWidth="500" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">

    <BorderPane fx:id="diamondPattern" layoutX="-239.0" layoutY="-61.0" prefHeight="290" prefWidth="390">

        <!-- Top section of the diamond -->
        <top>
            <VBox alignment="CENTER" spacing="6" BorderPane.alignment="CENTER">
                <!-- Row 1: 1 flag -->
                <HBox alignment="CENTER" spacing="6">
                    <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                        <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                    </Pane>
                </HBox>
                <!-- Row 2: 3 flags -->
                <HBox alignment="CENTER" spacing="6">
                    <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                        <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                    </Pane>
                    <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                        <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                    </Pane>
                    <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                        <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                    </Pane>
                </HBox>
            </VBox>
        </top>

        <center>
            <!-- Row 3: 5 flags (widest row) -->
            <HBox alignment="CENTER" spacing="6" BorderPane.alignment="CENTER">
                <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                    <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                </Pane>
                <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                    <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                </Pane>
                <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                    <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                </Pane>
                <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                    <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                </Pane>
                <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                    <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                </Pane>
            </HBox>
        </center>

        <bottom>
            <VBox alignment="CENTER" spacing="6" BorderPane.alignment="CENTER">
                <!-- Row 4: 3 flags -->
                <HBox alignment="CENTER" spacing="6">
                    <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                        <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                    </Pane>
                    <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                        <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                    </Pane>
                    <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                        <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                    </Pane>
                </HBox>
                <!-- Row 5: 1 flag -->
                <HBox alignment="CENTER" spacing="6">
                    <Pane maxHeight="45" maxWidth="90" minHeight="45" minWidth="90" prefHeight="45" prefWidth="90">
                        <fx:include scaleX="0.15" scaleY="0.15" source="flag.fxml" />
                    </Pane>
                </HBox>
            </VBox>
        </bottom>

    </BorderPane>

</AnchorPane>
